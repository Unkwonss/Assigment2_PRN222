<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#06080f" />
    <title>@ViewData["Title"] - VietRAG System</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
</head>
<body>
    <div class="bg-mesh" aria-hidden="true">
        <div class="bg-orb bg-orb-1"></div>
        <div class="bg-orb bg-orb-2"></div>
        <div class="bg-orb bg-orb-3"></div>
    </div>

    <header class="sticky-top">
        <nav class="navbar navbar-expand-lg navbar-dark bg-blur">
            <div class="container-fluid px-4">
                <a class="navbar-brand d-flex align-items-center gap-2" asp-page="/Index">
                    <div class="brand-logo-glow">
                        <i class="bi bi-cpu-fill fs-5 text-glow"></i>
                    </div>
                    <span>VietRAG <span class="badge-role">System</span></span>
                </a>

                <button class="navbar-toggler border-0 shadow-none" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav"
                        aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0 gap-1 mt-2 mt-lg-0">
                        <li class="nav-item">
                            <a class="nav-link-custom @(ViewContext.HttpContext.Request.Path == "/" ? "active" : "")" asp-page="/Index">
                                <i class="bi bi-house-fill"></i> Trang chủ
                            </a>
                        </li>
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            if (User.IsInRole("Admin"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link-custom @(ViewContext.HttpContext.Request.Path.StartsWithSegments("/Account/Users") ? "active" : "")" asp-page="/Account/Users">
                                        <i class="bi bi-people-fill"></i> Tài khoản
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link-custom @(ViewContext.HttpContext.Request.Path.StartsWithSegments("/Admin/ManageStudents") ? "active" : "")" asp-page="/Admin/ManageStudents">
                                        <i class="bi bi-mortarboard-fill"></i> Sinh viên
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link-custom @(ViewContext.HttpContext.Request.Path.StartsWithSegments("/Document") ? "active" : "")" asp-page="/Document/Index">
                                        <i class="bi bi-folder-fill"></i> Tài liệu
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link-custom @(ViewContext.HttpContext.Request.Path.StartsWithSegments("/Chat") ? "active" : "")" asp-page="/Chat/Index">
                                        <i class="bi bi-chat-left-text-fill"></i> Chatbot
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link-custom @(ViewContext.HttpContext.Request.Path.StartsWithSegments("/Benchmark") ? "active" : "")" asp-page="/Benchmark/Index">
                                        <i class="bi bi-bar-chart-line-fill"></i> Benchmark
                                    </a>
                                </li>
                            }
                            else if (User.IsInRole("Teacher"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link-custom @(ViewContext.HttpContext.Request.Path.StartsWithSegments("/Document") ? "active" : "")" asp-page="/Document/Index">
                                        <i class="bi bi-folder-fill"></i> Tài liệu
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link-custom @(ViewContext.HttpContext.Request.Path.StartsWithSegments("/Chat") ? "active" : "")" asp-page="/Chat/Index">
                                        <i class="bi bi-chat-left-text-fill"></i> Chatbot
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link-custom @(ViewContext.HttpContext.Request.Path.StartsWithSegments("/Benchmark") ? "active" : "")" asp-page="/Benchmark/Index">
                                        <i class="bi bi-bar-chart-line-fill"></i> Benchmark
                                    </a>
                                </li>
                            }
                            else
                            {
                                <li class="nav-item">
                                    <a class="nav-link-custom @(ViewContext.HttpContext.Request.Path.StartsWithSegments("/Chat") ? "active" : "")" asp-page="/Chat/Index">
                                        <i class="bi bi-chat-left-text-fill"></i> Học tập
                                    </a>
                                </li>
                            }
                        }
                    </ul>

                    <div class="d-flex align-items-center gap-3 mt-3 mt-lg-0 pb-2 pb-lg-0">
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <a asp-page="/Profile/Index" class="user-profile-nav d-none d-sm-flex align-items-center gap-2 text-decoration-none">
                                <div class="avatar-glow">
                                    <span>@(User.Identity.Name?.Length > 0 ? User.Identity.Name[0].ToString().ToUpper() : "?")</span>
                                </div>
                                <div class="profile-details text-start">
                                    <div class="profile-name">@User.Identity.Name</div>
                                    <div class="profile-role">@User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value</div>
                                </div>
                            </a>

                            <a class="btn btn-logout d-flex align-items-center gap-2" asp-page="/Account/Logout">
                                <i class="bi bi-box-arrow-right"></i> <span class="d-none d-md-inline">Đăng xuất</span>
                            </a>
                        }
                        else
                        {
                            <a class="btn btn-login-nav d-flex align-items-center gap-2" asp-page="/Account/Login">
                                <i class="bi bi-box-arrow-in-right"></i> Đăng nhập
                            </a>
                            <a class="btn btn-register-nav d-flex align-items-center gap-2" asp-page="/Account/Register">
                                <i class="bi bi-person-plus-fill"></i> Đăng ký
                            </a>
                        }
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <main role="main" class="main-content-area page-enter">
        @RenderBody()
    </main>

    <footer class="site-footer footer-blur mt-auto">
        <div class="container-fluid px-4">
            <div class="row align-items-center gy-3">
                <div class="col-md-4 text-center text-md-start">
                    <div class="footer-brand mb-1">VietRAG System</div>
                    <div class="text-muted-custom small">RAG Chatbot &amp; Research Benchmark</div>
                </div>
                <div class="col-md-4 text-center">
                    <div class="d-flex justify-content-center gap-4 flex-wrap">
                        <a asp-page="/Index" class="footer-link">Trang chủ</a>
                        <a asp-page="/Privacy" class="footer-link">Bảo mật</a>
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <a asp-page="/Profile/Index" class="footer-link">Hồ sơ</a>
                        }
                        else
                        {
                            <a asp-page="/Account/Login" class="footer-link">Đăng nhập</a>
                        }
                    </div>
                </div>
                <div class="col-md-4 text-center text-md-end">
                    <div class="text-muted-custom small">&copy; 2026 Group 4 SE1938 — FPT University</div>
                </div>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
