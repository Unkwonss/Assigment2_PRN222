@page
@model PRN222_assigment2.Pages.Account.LoginModel

@{
    ViewData["Title"] = "Đăng nhập";
    Layout = "_Layout";

    var authError = ViewData.ModelState.ContainsKey(string.Empty)
        ? ViewData.ModelState[string.Empty]?.Errors.FirstOrDefault()?.ErrorMessage
        : null;

    var emailServerErr = ViewData.ModelState.ContainsKey("Input.Email")
        ? ViewData.ModelState["Input.Email"]?.Errors.FirstOrDefault()?.ErrorMessage
        : null;
}

<div class="container auth-page">
    <div class="row w-100 justify-content-center">
        <div class="col-md-5 col-lg-4 auth-card">
            <div class="card-glass hover-scale shadow-lg">
                <div class="text-center mb-4">
                    <div class="d-inline-flex brand-logo-glow mb-3">
                        <i class="bi bi-cpu-fill fs-2 text-glow"></i>
                    </div>
                    <h3 class="card-title-gradient justify-content-center mb-1">Chào mừng quay lại</h3>
                    <p class="text-muted-custom">Hệ thống RAG Chatbot &amp; Research Benchmark</p>
                </div>

                @if (TempData["Success"] != null)
                {
                    <div class="d-flex align-items-center gap-2 mb-4 p-3"
                         style="background: rgba(25,135,84,0.18); border: 1px solid rgba(25,135,84,0.45); border-radius: 10px;">
                        <i class="bi bi-check-circle-fill flex-shrink-0" style="color: #6ee7b7;"></i>
                        <span style="color: #d1fae5; font-size: 0.9rem;">@TempData["Success"]</span>
                    </div>
                }

                <form method="post" autocomplete="off" id="loginForm" novalidate>
                    @Html.AntiForgeryToken()

                    <div class="mb-3">
                        <label asp-for="Input.Email" class="form-label text-muted-custom"></label>
                        <div class="input-group">
                            <span class="input-group-text bg-blur border-end-0 border-white border-opacity-10 text-muted-custom"
                                  style="border-radius: 8px 0 0 8px;">
                                <i class="bi bi-envelope"></i>
                            </span>
                            <input asp-for="Input.Email" type="email"
                                   class="form-control form-glass border-start-0"
                                   style="border-radius: 0 8px 8px 0; background: rgba(8,10,15,0.5) !important; color: #fff !important;"
                                   placeholder="email@example.com" />
                        </div>
                        @if (!string.IsNullOrEmpty(emailServerErr))
                        {
                            <div class="text-danger small mt-1">@emailServerErr</div>
                        }
                        <span asp-validation-for="Input.Email" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Input.Password" class="form-label text-muted-custom"></label>
                        <div class="input-group">
                            <span class="input-group-text bg-blur border-end-0 border-white border-opacity-10 text-muted-custom"
                                  style="border-radius: 8px 0 0 8px;">
                                <i class="bi bi-lock"></i>
                            </span>
                            <input asp-for="Input.Password" type="password"
                                   id="passwordInput"
                                   class="form-control form-glass border-start-0 border-end-0"
                                   style="background: rgba(8,10,15,0.5) !important; color: #fff !important;"
                                   placeholder="Mật khẩu" />
                            <button type="button" class="input-group-text bg-blur border-start-0 border-white border-opacity-10 text-muted-custom"
                                    id="togglePassword" style="border-radius: 0 8px 8px 0; cursor:pointer;">
                                <i class="bi bi-eye" id="eyeIcon"></i>
                            </button>
                        </div>
                        <span asp-validation-for="Input.Password" class="text-danger small"></span>
                    </div>

                    @if (!string.IsNullOrEmpty(authError))
                    {
                        <div class="d-flex align-items-center gap-2 mb-3 p-3"
                             style="background: rgba(220,38,38,0.15); border: 1px solid rgba(220,38,38,0.4); border-radius: 10px;">
                            <i class="bi bi-exclamation-triangle-fill flex-shrink-0" style="color: #fca5a5;"></i>
                            <span style="color: #fecaca; font-size: 0.88rem;">@authError</span>
                        </div>
                    }

                    <div class="d-grid mb-3">
                        <button type="submit" class="btn btn-glow-primary py-2 fw-semibold" id="submitBtn">
                            <i class="bi bi-box-arrow-in-right me-1"></i> Đăng nhập
                        </button>
                    </div>

                    <div class="text-center">
                        <span class="text-muted-custom small">Chưa có tài khoản? </span>
                        <a asp-page="/Account/Register" class="text-glow small fw-semibold">Đăng ký ngay</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        const toggleBtn = document.getElementById('togglePassword');
        const pwdInput = document.getElementById('passwordInput');
        const eyeIcon = document.getElementById('eyeIcon');
        if (toggleBtn) {
            toggleBtn.addEventListener('click', () => {
                const isPassword = pwdInput.type === 'password';
                pwdInput.type = isPassword ? 'text' : 'password';
                eyeIcon.className = isPassword ? 'bi bi-eye-slash' : 'bi bi-eye';
            });
        }
    </script>
}
