@page
@model PRN222_assigment2.Pages.ErrorModel
@{
    ViewData["Title"] = "Lỗi hệ thống";
}

<div class="error-page">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-8 col-lg-6 text-center">
                <div class="card-glass p-5 hover-scale">
                    <div class="error-code mb-2">500</div>
                    <div class="error-icon mb-4">
                        <i class="bi bi-exclamation-octagon-fill"></i>
                    </div>
                    <h2 class="fw-bold text-white mb-3">Đã xảy ra lỗi</h2>
                    <p class="text-muted-custom mb-4">
                        Hệ thống gặp sự cố khi xử lý yêu cầu của bạn. Vui lòng thử lại sau hoặc liên hệ quản trị viên.
                    </p>

                    @if (Model.ShowRequestId)
                    {
                        <div class="alert-glass alert-glass-warning justify-content-center mb-4">
                            <i class="bi bi-fingerprint"></i>
                            <div>
                                <strong>Request ID:</strong>
                                <code class="text-warning ms-1">@Model.RequestId</code>
                            </div>
                        </div>
                    }

                    <div class="d-flex justify-content-center gap-3 flex-wrap">
                        <a href="javascript:history.back()" class="btn btn-outline-glass d-flex align-items-center gap-2">
                            <i class="bi bi-arrow-left"></i> Quay lại
                        </a>
                        <a asp-page="/Index" class="btn btn-glow-primary d-flex align-items-center gap-2">
                            <i class="bi bi-house-fill"></i> Về trang chủ
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
