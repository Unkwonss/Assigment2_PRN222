@page
@model PRN222_assigment2.Pages.Benchmark.DashboardModel
@{
    ViewData["Title"] = "Benchmark Dashboard";

    double maxMrr = Model.Results.Any() ? Model.Results.Max(x => x.MRR) : 0;

    var strategies = Model.Results.Select(x => x.ChunkStrategy)
                          .Where(x => !string.IsNullOrEmpty(x))
                          .Distinct()
                          .ToList();
}

<div class="container-fluid px-4">
    <div class="page-header d-flex flex-column flex-sm-row justify-content-between align-items-start align-items-sm-center gap-3">
        <div>
            <h2 class="card-title-gradient mb-1">
                <i class="bi bi-graph-up-arrow text-glow"></i> Đánh giá So sánh RAG Models
            </h2>
            <p class="text-muted-custom mb-0">Phân tích hiệu năng Precision, Recall và MRR theo từng cấu hình mô hình</p>
        </div>
        <a asp-page="/Benchmark/Index" class="btn btn-outline-glass d-flex align-items-center gap-2">
            <i class="bi bi-arrow-left"></i> Về Benchmark Lab
        </a>
    </div>

    <!-- Stats summary -->
    @if (Model.Results.Any())
    {
        <div class="row g-3 mb-4">
            <div class="col-6 col-lg-3">
                <div class="stat-card">
                    <div class="stat-icon stat-icon-primary"><i class="bi bi-collection-fill"></i></div>
                    <div>
                        <div class="stat-value">@Model.Results.Count</div>
                        <div class="stat-label">Kết quả test</div>
                    </div>
                </div>
            </div>
            <div class="col-6 col-lg-3">
                <div class="stat-card">
                    <div class="stat-icon stat-icon-cyan"><i class="bi bi-bullseye"></i></div>
                    <div>
                        <div class="stat-value">@Model.Results.Average(x => x.Precision3).ToString("0.00")</div>
                        <div class="stat-label">Precision@3 TB</div>
                    </div>
                </div>
            </div>
            <div class="col-6 col-lg-3">
                <div class="stat-card">
                    <div class="stat-icon stat-icon-purple"><i class="bi bi-search"></i></div>
                    <div>
                        <div class="stat-value">@Model.Results.Average(x => x.Recall3).ToString("0.00")</div>
                        <div class="stat-label">Recall@3 TB</div>
                    </div>
                </div>
            </div>
            <div class="col-6 col-lg-3">
                <div class="stat-card">
                    <div class="stat-icon stat-icon-green"><i class="bi bi-trophy-fill"></i></div>
                    <div>
                        <div class="stat-value">@maxMrr.ToString("0.00")</div>
                        <div class="stat-label">MRR cao nhất</div>
                    </div>
                </div>
            </div>
        </div>
    }

    <!-- Filter & Export -->
    <div class="card-glass py-3 mb-4">
        <div class="row align-items-end g-3">
            <div class="col-md-5">
                <label for="strategyFilter" class="form-label text-muted-custom mb-1">Lọc theo Chunking Strategy</label>
                <select id="strategyFilter" class="form-select form-glass">
                    <option value="">— Tất cả Strategy —</option>
                    @foreach (var s in strategies)
                    {
                        <option value="@s">@s</option>
                    }
                </select>
            </div>
            <div class="col-md-7 text-md-end">
                <button class="btn btn-glow-success d-inline-flex align-items-center gap-2" onclick="exportTableToCSV('benchmark_results.csv')">
                    <i class="bi bi-file-earmark-spreadsheet"></i> Xuất CSV
                </button>
            </div>
        </div>
    </div>

    <!-- Chart -->
    <div class="card-glass mb-4">
        <div class="d-flex align-items-center gap-2 mb-3">
            <i class="bi bi-bar-chart-fill text-glow"></i>
            <h5 class="text-white fw-bold mb-0">Biểu đồ Precision@3 &amp; Recall@3</h5>
        </div>
        <div class="chart-container">
            <canvas id="metricsChart" height="100"></canvas>
        </div>
    </div>

    <!-- Table -->
    <div class="card-glass card-glass-flat">
        <div class="table-responsive">
            <table class="table table-glass align-middle mb-0" id="resultsTable">
                <thead>
                    <tr>
                        <th>Model</th>
                        <th>Chunk Strategy</th>
                        <th>Precision@3</th>
                        <th>Recall@3</th>
                        <th>MRR</th>
                        <th>Latency (ms)</th>
                        <th>Thời gian test</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Results.Any())
                    {
                        <tr>
                            <td colspan="7" class="text-center py-5 text-muted-custom">
                                <i class="bi bi-inbox fs-2 d-block mb-2 opacity-50"></i>
                                Không có dữ liệu benchmark nào.
                            </td>
                        </tr>
                    }
                    else
                    {
                        foreach (var item in Model.Results)
                        {
                            bool isBest = item.MRR == maxMrr && maxMrr > 0;
                            <tr class="data-row @(isBest ? "row-best" : "")" data-strategy="@item.ChunkStrategy">
                                <td class="fw-semibold text-white">@item.ModelName</td>
                                <td>
                                    <span class="badge-glass badge-role-teacher">@(string.IsNullOrEmpty(item.ChunkStrategy) ? "N/A" : item.ChunkStrategy)</span>
                                </td>
                                <td>@item.Precision3.ToString("0.000")</td>
                                <td>@item.Recall3.ToString("0.000")</td>
                                <td>
                                    @item.MRR.ToString("0.000")
                                    @if (isBest)
                                    {
                                        <span class="badge-glass badge-best ms-1">BEST</span>
                                    }
                                </td>
                                <td>@item.AvgLatencyMs.ToString("0.0")</td>
                                <td class="text-muted-custom">@item.RunAt.ToString("dd/MM/yyyy HH:mm")</td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const rawData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Results));
        let chartInstance = null;

        const chartColors = {
            precision: { bg: 'rgba(99, 102, 241, 0.7)', border: '#6366f1' },
            recall:    { bg: 'rgba(168, 85, 247, 0.7)', border: '#a855f7' }
        };

        function renderChart(data) {
            const ctx = document.getElementById('metricsChart').getContext('2d');
            const grouped = {};

            data.forEach(item => {
                let label = item.ModelName;
                if (item.ChunkStrategy) label += ' (' + item.ChunkStrategy + ')';
                if (!grouped[label]) grouped[label] = { p: 0, r: 0, count: 0 };
                grouped[label].p += item.Precision3;
                grouped[label].r += item.Recall3;
                grouped[label].count++;
            });

            const labels = Object.keys(grouped);
            const precisionData = labels.map(l => grouped[l].p / grouped[l].count);
            const recallData = labels.map(l => grouped[l].r / grouped[l].count);

            if (chartInstance) chartInstance.destroy();

            chartInstance = new Chart(ctx, {
                type: 'bar',
                data: {
                    labels,
                    datasets: [
                        {
                            label: 'Precision@3',
                            data: precisionData,
                            backgroundColor: chartColors.precision.bg,
                            borderColor: chartColors.precision.border,
                            borderWidth: 1,
                            borderRadius: 6
                        },
                        {
                            label: 'Recall@3',
                            data: recallData,
                            backgroundColor: chartColors.recall.bg,
                            borderColor: chartColors.recall.border,
                            borderWidth: 1,
                            borderRadius: 6
                        }
                    ]
                },
                options: {
                    responsive: true,
                    plugins: {
                        legend: {
                            labels: { color: '#94a3b8', font: { family: 'Plus Jakarta Sans' } }
                        }
                    },
                    scales: {
                        x: {
                            ticks: { color: '#64748b', maxRotation: 45 },
                            grid: { color: 'rgba(255,255,255,0.05)' }
                        },
                        y: {
                            beginAtZero: true,
                            max: 1.0,
                            ticks: { color: '#64748b' },
                            grid: { color: 'rgba(255,255,255,0.05)' }
                        }
                    }
                }
            });
        }

        renderChart(rawData);

        document.getElementById('strategyFilter').addEventListener('change', function () {
            const selected = this.value;
            document.querySelectorAll('.data-row').forEach(row => {
                const strategy = row.getAttribute('data-strategy');
                row.style.display = (selected === '' || strategy === selected) ? '' : 'none';
            });
            renderChart(selected === '' ? rawData : rawData.filter(x => x.ChunkStrategy === selected));
        });

        function exportTableToCSV(filename) {
            const rows = document.querySelectorAll('#resultsTable tr');
            let csv = [];
            for (let i = 0; i < rows.length; i++) {
                if (rows[i].style.display === 'none') continue;
                let row = [], cols = rows[i].querySelectorAll('td, th');
                for (let j = 0; j < cols.length; j++) {
                    let data = cols[j].innerText.replace(/(\r\n|\n|\r)/gm, '').trim().replace(/"/g, '""');
                    row.push('"' + data + '"');
                }
                csv.push(row.join(','));
            }
            const blob = new Blob([csv.join('\n')], { type: 'text/csv;charset=utf-8;' });
            const link = document.createElement('a');
            link.href = URL.createObjectURL(blob);
            link.download = filename;
            link.click();
        }
    </script>
}
