@page
@model PRN222_assigment2.Pages.Admin.ManageStudentsModel


@{
    ViewData["Title"] = "Quản lý sinh viên";
    Layout = "_Layout";
}

<div class="container-fluid px-4">
    <div class="d-flex flex-column flex-sm-row justify-content-between align-items-start align-items-sm-center gap-3 mb-4">
        <div>
            <h2 class="card-title-gradient mb-1">
                <i class="bi bi-mortarboard-fill text-glow"></i> Quản lý sinh viên
            </h2>
            <p class="text-muted-custom mb-0">
                Hiển thị danh sách sinh viên nội bộ và quản lý tài khoản.
            </p>
        </div>

        <div class="d-flex gap-2">
            <button class="btn btn-outline-glass d-flex align-items-center gap-2"
                    data-bs-toggle="modal" data-bs-target="#importCsvModal">
                <i class="bi bi-file-earmark-excel-fill text-success"></i> Import CSV
            </button>
            <button class="btn btn-glow-primary d-flex align-items-center gap-2"
                    data-bs-toggle="modal" data-bs-target="#addStudentModal">
                <i class="bi bi-plus-circle-fill"></i> Thêm sinh viên
            </button>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <script>
            document.addEventListener('DOMContentLoaded', function() {
                Swal.fire({
                    icon: 'success',
                    title: 'Thành công!',
                    text: '@Html.Raw(TempData["Success"])',
                    background: 'rgba(13, 17, 28, 0.95)',
                    color: '#fff',
                    confirmButtonColor: '#6366f1'
                });
            });
        </script>
    }
    @if (TempData["Error"] != null)
    {
        <script>
            document.addEventListener('DOMContentLoaded', function() {
                Swal.fire({
                    icon: 'error',
                    title: 'Thất bại!',
                    text: '@Html.Raw(TempData["Error"])',
                    background: 'rgba(13, 17, 28, 0.95)',
                    color: '#fff',
                    confirmButtonColor: '#ef4444'
                });
            });
        </script>
    }

    <!-- Search bar -->
    <div class="card-glass py-3 mb-4">
        <form asp-page="/Admin/ManageStudents" method="get" id="searchForm">
            <div class="row align-items-center g-3">
                <div class="col-md-9">
                    <div class="input-group">
                        <span class="input-group-text bg-blur border-end-0 border-white border-opacity-10 text-muted-custom" style="border-radius: 8px 0 0 8px;">
                            <i class="bi bi-search"></i>
                        </span>
                        <input type="text" name="searchTerm" value="@Model.SearchTerm"
                               class="form-control form-glass border-start-0" style="border-radius: 0 8px 8px 0;"
                               placeholder="Tìm kiếm theo Tên, Email, Username..." id="searchInput"
                               autocomplete="off" />
                    </div>
                </div>
                <div class="col-md-3">
                    <button type="submit" class="btn btn-glow-primary w-100">
                        <i class="bi bi-search"></i> Tìm kiếm
                    </button>
                </div>
            </div>
        </form>
    </div>

    <!-- Student Table -->
    <div class="card-glass p-0 overflow-hidden shadow-lg">
        <div class="table-responsive">
            <table class="table table-glass mb-0">
                <thead>
                    <tr>
                        <th style="width:80px;">ID</th>
                        <th>Họ và tên</th>
                        <th>Username</th>
                        <th>Email</th>
                        <th>Vai trò</th>
                        <th class="text-end">Trạng thái mật khẩu</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Students.Any())
                    {
                        <tr>
                            <td colspan="6" class="text-center py-5">
                                <i class="bi bi-mortarboard fs-1 text-muted-custom d-block mb-2"></i>
                                <span class="text-muted-custom">Chưa có sinh viên nào trong hệ thống.</span>
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var student in Model.Students)
                        {
                            <tr>
                                <td><strong class="text-muted-custom">#@student.UserId</strong></td>
                                <td>
                                    <div class="d-flex align-items-center gap-2">
                                        <div class="avatar-glow" style="width: 28px; height: 28px; font-size: 0.8rem;">
                                            @student.FullName[0].ToString().ToUpper()
                                        </div>
                                        <span class="fw-semibold text-white">@student.FullName</span>
                                    </div>
                                </td>
                                <td><code class="text-glow text-opacity-75">@student.Username</code></td>
                                <td class="text-white">@student.Email</td>
                                <td>
                                    <span class="badge bg-success bg-opacity-25 text-success border border-success border-opacity-20 px-2 py-1">Student</span>
                                </td>
                                <td class="text-end">
                                    @* We will check using UserService to see if it is default password. Since we are in Razor, let's just output a placeholder or check it *@
                                    <span class="badge bg-secondary bg-opacity-25 text-muted-custom px-2 py-1">Đã khởi tạo</span>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Modal Add Student -->
<div class="modal fade" id="addStudentModal" tabindex="-1" aria-labelledby="addStudentModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content modal-content-glass">
            <div class="modal-header modal-header-glass">
                <h5 class="modal-title card-title-gradient mb-0" id="addStudentModalLabel">
                    <i class="bi bi-plus-circle-fill text-glow"></i> Thêm sinh viên mới
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form asp-page-handler="AddStudent" method="post" id="addStudentForm">
                @Html.AntiForgeryToken()
                <div class="modal-body p-4">
                    <div class="mb-3">
                        <label class="form-label text-muted-custom">Họ và tên <span class="text-danger">*</span></label>
                        <input type="text" name="fullName" class="form-control form-glass" placeholder="Nguyễn Văn A" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label text-muted-custom">Email <span class="text-danger">*</span></label>
                        <input type="email" name="email" class="form-control form-glass" placeholder="anv@fpt.edu.vn" required />
                    </div>
                    <div class="alert alert-info bg-opacity-10 text-info border-info border-opacity-25">
                        <i class="bi bi-info-circle-fill"></i> Mật khẩu mặc định sẽ là <strong>FptStudent@@123</strong>. Tài khoản sẽ tự động sinh username không dấu viết liền.
                    </div>
                </div>
                <div class="modal-footer modal-footer-glass">
                    <button type="button" class="btn btn-outline-glass" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" class="btn btn-glow-primary">Tạo sinh viên</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Modal Import CSV -->
<div class="modal fade" id="importCsvModal" tabindex="-1" aria-labelledby="importCsvModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content modal-content-glass">
            <div class="modal-header modal-header-glass">
                <h5 class="modal-title card-title-gradient mb-0" id="importCsvModalLabel">
                    <i class="bi bi-file-earmark-excel-fill text-glow"></i> Import sinh viên từ file CSV
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form asp-page-handler="ImportCsv" method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()
                <div class="modal-body p-4">
                    <div class="mb-3">
                        <label class="form-label text-muted-custom">Chọn file CSV (.csv, .txt) <span class="text-danger">*</span></label>
                        <input type="file" name="csvFile" class="form-control form-glass" accept=".csv,.txt" required />
                    </div>
                    <div class="alert alert-warning bg-opacity-10 text-warning border-warning border-opacity-25">
                        <h6>Định dạng file CSV chuẩn:</h6>
                        <pre class="m-0 text-white" style="font-size: 0.85rem;">FullName,Email
Nguyen Van A,anv@@fpt.edu.vn
Le Thi B,btl@@fpt.edu.vn</pre>
                    </div>
                </div>
                <div class="modal-footer modal-footer-glass">
                    <button type="button" class="btn btn-outline-glass" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" class="btn btn-glow-primary">Bắt đầu Import</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Live search delay
        var searchTimer;
        document.getElementById('searchInput').addEventListener('keyup', function() {
            clearTimeout(searchTimer);
            searchTimer = setTimeout(function() {
                document.getElementById('searchForm').submit();
            }, 500);
        });
    </script>
}


