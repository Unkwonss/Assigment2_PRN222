@page
@model PRN222_assigment2.Pages.Profile.IndexModel
@{
    ViewData["Title"] = "Trang cá nhân";
    Layout = "_Layout";
    bool isDefaultPassword = Model.IsDefaultPassword;
    var user = Model.CurrentUser;
    var initial = !string.IsNullOrEmpty(user?.FullName) ? user.FullName[0].ToString().ToUpper() : "?";
    var roleClass = user?.Role?.ToLower() switch
    {
        "admin" => "badge-role-admin",
        "teacher" => "badge-role-teacher",
        _ => "badge-role-student"
    };
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-lg-9">

            @if (TempData["Success"] != null)
            {
                <div class="alert-glass alert-glass-success" data-auto-dismiss>
                    <i class="bi bi-check-circle-fill fs-5"></i>
                    <div>@TempData["Success"]</div>
                </div>
            }

            @if (TempData["Error"] != null)
            {
                <div class="alert-glass alert-glass-danger">
                    <i class="bi bi-exclamation-triangle-fill fs-5"></i>
                    <div>@TempData["Error"]</div>
                </div>
            }

            @if (TempData["Warning"] != null || isDefaultPassword)
            {
                <div class="alert-glass alert-glass-warning">
                    <i class="bi bi-exclamation-octagon-fill fs-5"></i>
                    <div>
                        <strong>Yêu cầu bảo mật:</strong>
                        @(TempData["Warning"] ?? "Bạn đang sử dụng mật khẩu mặc định. Vui lòng đổi mật khẩu để bảo vệ tài khoản.")
                    </div>
                </div>
            }

            <div class="card-glass shadow-lg mb-4">
                <div class="p-4 p-sm-5">
                    <div class="d-flex flex-column flex-sm-row align-items-center gap-4 border-bottom border-white border-opacity-10 pb-4 mb-4">
                        <div class="avatar-glow avatar-glow-lg">@initial</div>
                        <div class="text-center text-sm-start">
                            <h3 class="fw-bold text-white mb-2">@(user?.FullName ?? "—")</h3>
                            <p class="text-muted-custom mb-0 d-flex align-items-center justify-content-center justify-content-sm-start gap-2 flex-wrap">
                                <span class="badge-glass @roleClass">@(user?.Role ?? "—")</span>
                                <span>&bull;</span>
                                <span><i class="bi bi-envelope me-1"></i>@(user?.Email ?? "—")</span>
                            </p>
                        </div>
                    </div>

                    <div class="row g-4">
                        <div class="col-md-6">
                            <h5 class="text-white fw-bold mb-3">
                                <i class="bi bi-person-vcard text-glow me-2"></i>Thông tin tài khoản
                            </h5>

                            <div class="mb-3">
                                <label class="small text-muted-custom d-block mb-1">Tên đăng nhập</label>
                                <div class="form-control form-readonly py-2 px-3">@(user?.Username ?? "—")</div>
                            </div>

                            <div class="mb-3">
                                <label class="small text-muted-custom d-block mb-1">Địa chỉ Email</label>
                                <div class="form-control form-readonly py-2 px-3">@(user?.Email ?? "—")</div>
                            </div>

                            <div class="mb-0">
                                <label class="small text-muted-custom d-block mb-1">Họ và tên</label>
                                <div class="form-control form-readonly py-2 px-3">@(user?.FullName ?? "—")</div>
                            </div>
                        </div>

                        <div class="col-md-6 border-start border-white border-opacity-10 ps-md-4">
                            <h5 class="text-white fw-bold mb-3">
                                <i class="bi bi-key-fill text-glow me-2"></i>Đổi mật khẩu
                            </h5>

                            <form asp-page-handler="ChangePassword" method="post">
                                @Html.AntiForgeryToken()

                                <div class="mb-3">
                                    <label class="form-label text-muted-custom">Mật khẩu hiện tại</label>
                                    <input type="password" name="oldPassword" class="form-control form-glass" required placeholder="Nhập mật khẩu hiện tại" />
                                </div>

                                <div class="mb-3">
                                    <label class="form-label text-muted-custom">Mật khẩu mới</label>
                                    <input type="password" name="newPassword" class="form-control form-glass" required placeholder="Ít nhất 6 ký tự" minlength="6" />
                                </div>

                                <div class="mb-3">
                                    <label class="form-label text-muted-custom">Xác nhận mật khẩu mới</label>
                                    <input type="password" name="confirmPassword" class="form-control form-glass" required placeholder="Nhập lại mật khẩu mới" minlength="6" />
                                </div>

                                <button type="submit" class="btn btn-glow-primary w-100 py-2 mt-1">
                                    <i class="bi bi-shield-lock-fill me-1"></i> Cập nhật mật khẩu
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>
