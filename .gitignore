## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.
##
## Original source: https://github.com/github/gitignore/blob/main/VisualStudio.gitignore

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# User-specific files (MonoDevelop/Xamarin Studio)
*.userprefs

# Mono auto generated files
*.pidb

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Re]leases/
x64/
x86/
[Aa]rm/
[Aa]rm64/
bld/
[Bb]in/
[Oo]bj/
[Log]s/
[Ff]ormats/

# Visual Studio 2015/2017/2019/2022 cache directory
.vs/
# Generated user secrets file
secrets.json

# ASP.NET Core appsettings files with secrets
**/appsettings.json
**/appsettings.Development.json
**/appsettings.Production.json
!**/appsettings.json.example

# Rider
.idea/

# VS Code
.vscode/
